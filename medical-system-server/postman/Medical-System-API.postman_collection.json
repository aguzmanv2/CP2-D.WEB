    {
      "name": "Turnos",
      "item": [
        {
          "name": "Register Arrival",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cita\": \"{{appointmentId}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/turnos/registrar-llegada" }
          }
        },
        {
          "name": "Queue",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/turnos/cola?medico={{doctorId}}&fecha=" }
          }
        },
        {
          "name": "Current Turn",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/turnos/actual?medico={{doctorId}}&fecha=" }
          }
        },
        {
          "name": "Next Turn",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/turnos/siguiente?medico={{doctorId}}&fecha=" }
          }
        },
        {
          "name": "Patient Turn",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/turnos/paciente?paciente={{patientId}}&fecha=" }
          }
        },
        {
          "name": "History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/turnos/historial?medico={{doctorId}}&paciente={{patientId}}&estado=&fecha=&page=1&limit=10" }
          }
        },
        {
          "name": "Start Attention",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"turnoId\": \"{{turnId}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/turnos/atender" }
          }
        },
        {
          "name": "Finish Attention",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"turnoId\": \"{{turnId}}\",\n  \"motivo\": \"Control de seguimiento\",\n  \"notas\": \"Consulta cerrada desde Postman\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/turnos/finalizar" }
