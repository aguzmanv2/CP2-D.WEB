          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cedula\": \"1-1111-1111\",\n  \"nombre\": \"Juan\",\n  \"apellido\": \"Perez\",\n  \"correo\": \"juan.perez@example.com\",\n  \"password\": \"Password123\",\n  \"rol\": \"Paciente\"\n}"
